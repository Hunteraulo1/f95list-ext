{
  "name": "f95list-ext",
  "version": "2.2.17",
  "author": {
    "email": "hunteraulo@pm.me",
    "name": "Hunteraulo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hunteraulo1/f95list-ext"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    },
    "cz-emoji": {
      "skipQuestions": [
        "scope",
        "body"
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@lucide/svelte": "1.21.0",
    "@tailwindcss/vite": "4.3.1",
    "@tsconfig/svelte": "5.0.8",
    "@types/chrome": "0.2.0",
    "@wxt-dev/module-svelte": "2.0.5",
    "bits-ui": "2.18.1",
    "clsx": "2.1.1",
    "mode-watcher": "1.1.0",
    "paneforge": "1.0.2",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "svelte-sonner": "1.1.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.3.1",
    "tslib": "2.8.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "valibot": "1.4.1",
    "vaul-svelte": "1.0.0-next.7",
    "wxt": "0.20.27"
  },
  "overrides": {
    "vaul-svelte": ">=1.0.0-next.1"
  },
  "description": "Extension de F95 France permettant de lister les traductions",
  "license": "UNLICENSED",
  "private": false,
  "scripts": {
    "dev:chrome": "wxt --debug",
    "dev:firefox": "wxt -b firefox --debug",
    "build": "bun run build:chrome && bun run build:firefox",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "bunx @biomejs/biome check --write . && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx @biomejs/biome check --write . && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "bunx @biomejs/biome lint --write .",
    "format": "bunx @biomejs/biome format --write .",
    "postinstall": "wxt prepare"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide",
    "dtrace-provider",
    "esbuild",
    "spawn-sync"
  ],
  "type": "module",
  "dependencies": {
    "svelte-lazy": "1.2.11"
  }
}
